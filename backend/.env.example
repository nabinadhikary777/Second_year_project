# Khalti — copy to .env and fill in (do not commit .env)
KHALTI_SECRET_KEY=your_secret_key_here
KHALTI_PUBLIC_KEY=your_public_key_here
KHALTI_API_URL=https://dev.khalti.com/api/v2
FRONTEND_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# Email (set these to enable real email delivery for password reset)
# Example for Gmail SMTP:
# EMAIL_HOST_USER=youremail@gmail.com
# EMAIL_HOST_PASSWORD=your_16_char_app_password
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=SawariSewa <noreply@sawarisewa.com>
